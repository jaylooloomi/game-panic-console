<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>

    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <!-- Compile the engine-agnostic game code + tests that live in the Unity Assets tree.
       This lets us verify Task 0-7 logic with `dotnet test` before Unity is installed.
       Unity ignores this tools/ folder (it only compiles under Assets/). -->
  <ItemGroup>
    <Compile Include="../../Assets/Scripts/Core/**/*.cs" />
    <Compile Include="../../Assets/Scripts/Minigames/**/*.cs" />
    <Compile Include="../../Assets/Tests/EditMode/**/*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" Version="6.0.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="NUnit" Version="3.14.0" />
    <PackageReference Include="NUnit.Analyzers" Version="3.9.0" />
    <PackageReference Include="NUnit3TestAdapter" Version="4.5.0" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="NUnit.Framework" />
  </ItemGroup>

</Project>
